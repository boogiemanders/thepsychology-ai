{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "thepsychology.ai" }],
      "destination": "https://www.thepsychology.ai/:path*",
      "permanent": true
    }
  ],
  "functions": {
    "api/dental/extract.py": {
      "memory": 1024,
      "maxDuration": 300,
      "excludeFiles": "{lab/**,public/**,content/**,podcast-output/**,podcast-upload/**,tools-generation/**,staging/**,exams/**,examsGPT/**,questionsGPT/**,topic-content/**,topic-content-v3-test/**,topic-content-v4/**,topic-content-v4 copy/**,eppp-reference/**,eppp-reference og/**,src/**,.next/**,node_modules/**,homepage-full.png}"
    }
  },
  "crons": [
    {
      "path": "/api/cron/backfill-referral-source",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/recover-digest",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/daily-stats",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/hourly-activity-digest",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/expire-trials",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/activation-nudge",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/check-nysed-licenses",
      "schedule": "0 12 * * *"
    }
  ]
}
