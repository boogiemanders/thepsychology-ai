{
  "manifest_version": 3,
  "name": "SimplePractice Notes",
  "version": "1.0.0",
  "description": "HIPAA-compliant clinical notes: extract intake data, generate diagnostic impressions, record sessions, and auto-fill progress notes",
  "permissions": ["storage", "activeTab", "alarms", "sidePanel"],
  "host_permissions": [
    "https://*.simplepractice.com/*",
    "https://thepsychology.ai/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.simplepractice.com/*"],
      "js": ["content/extract-intake.js", "content/fill-note.js"],
      "css": ["content/content.css"]
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
